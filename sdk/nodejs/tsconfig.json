{
    "compilerOptions": {
        // Output
        "outDir": "bin",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "stripInternal": true,
        // Environment
        "target": "ES2022",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "moduleDetection": "force",
        "types": ["node"],
        // Type Checking
        "strict": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitReturns": true,
        "skipLibCheck": true
    },
    "files": [
        "addon.ts",
        "cluster.ts",
        "clusterCreationRoleProvider.ts",
        "clusterMixins.ts",
        "index.ts",
        "managedNodeGroup.ts",
        "nodeGroup.ts",
        "nodeGroupSecurityGroup.ts",
        "nodeGroupV2.ts",
        "nodegroupMixins.ts",
        "provider.ts",
        "storageclassMixins.ts",
        "types/enums/index.ts",
        "types/index.ts",
        "types/input.ts",
        "types/output.ts",
        "utilities.ts",
        "vpcCniAddon.ts"
    ]
}
